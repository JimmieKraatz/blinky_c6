# Required
GH_REPO_URL=https://github.com/JimmieKraatz/blinky_c6
GH_RUNNER_TOKEN=REPLACE_WITH_EPHEMERAL_REGISTRATION_TOKEN

# Optional
GH_RUNNER_NAME=blinky-hil-runner
GH_RUNNER_LABELS=self-hosted,linux,hil,esp32c6
GH_RUNNER_GROUP=Default
GH_RUNNER_WORKDIR=_work
GH_RUNNER_REPLACE=true

# Serial device exposed to runner container
HIL_SERIAL_DEVICE=/dev/ttyACM0
# Serial device group id from host (run: stat -c '%g' /dev/ttyACM0)
HIL_SERIAL_GID=20
